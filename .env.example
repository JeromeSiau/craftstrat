APP_NAME=CraftStrat
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=craftstrat
DB_USERNAME=craftstrat
DB_PASSWORD=craftstrat_secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

ENGINE_INTERNAL_URL=http://engine:8080
ML_MODEL_NAME=btc-15m-xgb-policy
ML_TRAINER_URL=http://ml-trainer:8011
ML_TRAINER_TIMEOUT=30
ML_TRAINER_ENABLED=false
ML_TRAINER_SCHEDULE_AT=03:15
ML_TRAINER_SCHEDULE_TIMEZONE=UTC
ML_REFRESH_SLOT_DURATION=900
ML_REFRESH_SYMBOLS=BTC
ML_REFRESH_HOURS=720
ML_REFRESH_SAMPLE_EVERY=6
ML_REFRESH_LIMIT=5000
ML_REFRESH_MAX_ROWS=0
ML_TRAIN_VERBOSE_EVAL=50
ML_TRAIN_RL_GAMMA=0.999
ENCRYPTION_KEY=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

CLICKHOUSE_URL=http://default:clickhouse@clickhouse:8123

KAFKA_BROKERS=kafka:9092

POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=

# Comma-separated proxy URLs for Polymarket API calls (HTTP only, not WSS)
# Example: http://user:pass@se1.proxy.com:8080,http://user:pass@se2.proxy.com:8080
PROXY_LIST=
